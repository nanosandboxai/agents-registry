ARG BASE_IMAGE=agents-registry/base:latest
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.description="Codex agent for nanosandbox sandboxes"

# Install codex CLI plus its platform-specific native binary. The wrapper
# package @openai/codex depends on @openai/codex-linux-x64 (or -arm64) via
# optionalDependencies — these are aliases pointing at tagged versions of
# @openai/codex itself (e.g. npm:@openai/codex@0.121.0-linux-x64). buildx
# multi-arch builds under QEMU skip optional deps whose cpu/os constraints
# don't match detection, leaving runtime broken with "Missing optional
# dependency @openai/codex-linux-x64". Install it explicitly using the
# same alias form the wrapper resolves at runtime.
RUN npm install -g @openai/codex \
    && CODEX_VERSION="$(npm view @openai/codex version)" \
    && ARCH="$(uname -m)" \
    && case "$ARCH" in \
         x86_64)  PLATFORM="linux-x64" ;; \
         aarch64) PLATFORM="linux-arm64" ;; \
         *) echo "Unsupported arch for codex: $ARCH" >&2; exit 1 ;; \
       esac \
    && npm install -g "@openai/codex-${PLATFORM}@npm:@openai/codex@${CODEX_VERSION}-${PLATFORM}" \
    && npm cache clean --force

RUN codex --version && echo "Codex: OK"
RUN rm -rf /workspace/*

CMD ["/usr/local/bin/nanosb-init.sh"]
