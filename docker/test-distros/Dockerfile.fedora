FROM fedora:40

WORKDIR /build
COPY scripts/ci/install-deps-dnf.sh /tmp/install-deps.sh
RUN bash /tmp/install-deps.sh && rm /tmp/install-deps.sh

COPY . /build
RUN git config --global --add safe.directory /build

# Build + unit tests only. No KVM needed.
CMD ["bash", "scripts/ci/build-and-test.sh"]
